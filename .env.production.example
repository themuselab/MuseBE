# BE 운영용 환경변수 템플릿. 실제 값은 VM 위에서 .env로 복사 후 채울 것.
# 서버 컨테이너 내부 통신은 docker-compose가 자동 주입(DATABASE_URL/REDIS_URL/PIL_SERVICE_URL)하므로 여기엔 시크릿/외부 키만 둠.

NODE_ENV=production
PORT=4000

# Postgres (compose가 사용)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME_DB_PASSWORD__
POSTGRES_DB=muse

# JWT
JWT_SECRET=__CHANGE_ME_RANDOM_64_CHARS__
JWT_REFRESH_SECRET=__CHANGE_ME_DIFFERENT_RANDOM_64_CHARS__

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.themuselab.kr/auth/google/callback

# CORS
FRONTEND_URL=https://themuselab.vercel.app

# AI 키
FAL_KEY=
OPENAI_API_KEY=

# PIL service feature flags
# PIL_HAS_CTA=true 일 때 PIL `/overlay`가 cta 인자 별도 지원 (옵션 A 정식 마이그 후 사용).
# 기본 false: BE에서 cta를 subhead 줄에 합쳐 보내는 fallback (옵션 B).
PIL_HAS_CTA=false

# LoRA URLs
# MUSE_LORA_URL: v3 (자연 매거진 톤, plasticky 해결) — fal.media CDN
MUSE_LORA_URL=https://v3b.fal.media/files/b/0a990063/RBKGAKuRvBy8q1AAPb1Xa_muse_lora_v3.safetensors
REALISM_LORA_URL=https://huggingface.co/XLabs-AI/flux-RealismLora/resolve/main/lora.safetensors
KODA_LORA_URL=https://huggingface.co/alvdansen/flux-koda/resolve/main/araminta_k_flux_koda.safetensors
WHINDY_LORA_URL=https://huggingface.co/musecall/face-impression-analyzer/resolve/main/whindy/whindy_lora_v1.safetensors
