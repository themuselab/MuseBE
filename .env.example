DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muse?schema=public"
PORT=4000
JWT_SECRET=
JWT_REFRESH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
FRONTEND_URL=http://localhost:3000

# AI Integration
FAL_KEY=
OPENAI_API_KEY=
REDIS_URL=redis://localhost:6379
PIL_SERVICE_URL=http://localhost:8001

# PIL service feature flags
# PIL_HAS_CTA=true 일 때 PIL `/overlay` 엔드포인트가 cta 인자를 따로 받음.
# 기본값(false)은 BE에서 cta를 subhead 줄에 합쳐 보내는 fallback (옵션 B).
PIL_HAS_CTA=false

# LoRA URLs
# MUSE_LORA_URL: v3 (자연 매거진 톤, plasticky 해결) — fal.media CDN
MUSE_LORA_URL=https://v3b.fal.media/files/b/0a990063/RBKGAKuRvBy8q1AAPb1Xa_muse_lora_v3.safetensors
REALISM_LORA_URL=https://huggingface.co/XLabs-AI/flux-RealismLora/resolve/main/lora.safetensors
KODA_LORA_URL=https://huggingface.co/alvdansen/flux-koda/resolve/main/araminta_k_flux_koda.safetensors
WHINDY_LORA_URL=https://huggingface.co/musecall/face-impression-analyzer/resolve/main/whindy/whindy_lora_v1.safetensors

# Email (Resend)
# 로컬: from을 onboarding@resend.dev로 두면 본인 Resend 가입 이메일로만 발송됨
# 운영: themuselab.kr 도메인 검증 후 noreply@themuselab.kr 사용
RESEND_API_KEY=
EMAIL_FROM="muse <themuselab@resend.dev>"

# Discord webhook for pre-registration notifications (success + errors)
DISCORD_WEBHOOK_URL=
